@{
    ViewData["Title"] = "Developer Workload Report";
}

<div class="container mt-4">
    <div class="d-flex align-items-center mb-4">
        <h2>Developer Workload Report</h2>
    </div>

    <!-- SEÇİM ALANI (Glass Form Kullanıldı) -->
    <div class="glass-form-container theme-reports mb-4" style="padding: 20px;">
        <div class="row">
            <div class="col-md-6">
                <label for="developerSelect" class="form-label fw-bold">Select Developer</label>
                <select id="developerSelect" class="form-select glass-input" asp-items="ViewBag.Developers">
                    <option value="">-- Choose a developer to see their tasks --</option>
                </select>
            </div>
        </div>
    </div>

    <!-- TABLO ALANI (Glass Table Kullanıldı, Başlangıçta Gizli) -->
    <div class="glass-table-container theme-reports d-none" id="reportCard">
        <div class="d-flex justify-content-between align-items-center mb-3 px-2">
            <h5 class="mb-0 text-white fw-bold" id="reportTitle">Assigned Tasks</h5>
            <span class="badge bg-light text-dark opacity-75 fs-6" id="taskCountBadge">0 Tasks</span>
        </div>

        <table class="glass-table">
            <thead>
                <tr>
                    <th>Task Title</th>
                    <th>Project Name</th>
                    <th class="text-end pe-4">Status</th>
                </tr>
            </thead>
            <!-- AJAX ile dolacak olan gövde -->
            <tbody id="tasksTableBody">
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Dropdown'da seçim değiştiği anda bu fonksiyon çalışır
            $('#developerSelect').change(function () {
                var devId = $(this).val();
                var devName = $("#developerSelect option:selected").text();
                var tbody = $('#tasksTableBody');
                var card = $('#reportCard');
                var countBadge = $('#taskCountBadge');

                // Eğer "Choose a developer" (boş) seçildiyse tabloyu geri gizle
                if (!devId) {
                    card.addClass('d-none');
                    return;
                }

                // Yükleniyor durumunu göster (Cam tasarıma uygun beyaz loader)
                tbody.html('<tr><td colspan="3" class="text-center py-4"><div class="spinner-border text-light" role="status"></div><span class="ms-2 text-light">Loading tasks...</span></td></tr>');
                card.removeClass('d-none');
                $('#reportTitle').text(devName + ' - Task List');

                // Controller'daki metoda AJAX GET isteği fırlat
                $.ajax({
                    url: '/Reports/GetTasksByDeveloper',
                    type: 'GET',
                    data: { developerId: devId }, // Controller'daki parametre adı ile eşleşmeli
                    success: function (data) {
                        tbody.empty(); // Tabloyu temizle
                        countBadge.text(data.length + " Tasks");

                        if (data && data.length > 0) {
                            // Gelen JSON dizisindeki her bir görev için döngüye gir ve tabloya cam satır (tr) ekle
                            $.each(data, function (index, task) {

                                // Gelen verideki statüye göre Cam Temaya uygun (opacity-75) Badge rengi belirle
                                var statusBadge = '';
                                if(task.status === "Done") statusBadge = '<span class="badge bg-success opacity-75">Done</span>';
                                else if (task.status === "In Progress") statusBadge = '<span class="badge bg-warning text-dark opacity-75">In Progress</span>';
                                else statusBadge = '<span class="badge bg-light text-dark opacity-75">' + task.status + '</span>';

                                var row = '<tr>' +
                                    '<td class="fw-bold">' + task.title + '</td>' +
                                    '<td>' + task.projectName + '</td>' +
                                    '<td class="text-end pe-4">' + statusBadge + '</td>' +
                                    '</tr>';

                                tbody.append(row); // Satırı tabloya göm
                            });
                        } else {
                            tbody.html('<tr><td colspan="3" class="text-center py-4 opacity-75">No active tasks found for this developer.</td></tr>');
                        }
                    },
                    error: function () {
                        tbody.html('<tr><td colspan="3" class="text-center py-4 text-warning fw-bold">An error occurred while fetching data!</td></tr>');
                    }
                });
            });
        });
    </script>
}