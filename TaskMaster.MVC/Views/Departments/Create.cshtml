@model TaskMaster.MVC.DTOs.DepartmentDto
@{ ViewData["Title"] = "Create Department"; }

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="glass-form-container theme-departments">
                <h3 class="mb-4 border-bottom pb-2 border-light border-opacity-25">Add New Department</h3>
                
                <form asp-action="Create" method="post">
                    <div class="mb-4">
                        <label asp-for="Name" class="form-label fw-bold">Department Name</label>
                        <input asp-for="Name" class="form-control glass-input" placeholder="e.g. IT / Frontend" />
                        <span asp-validation-for="Name" class="text-dark fw-bold"></span> </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-glass text-dark border-dark">Back to List</a>
                        <button type="submit" class="btn btn-glass text-dark border-dark fw-bold">Save Department</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }