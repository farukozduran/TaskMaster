@model TaskMaster.MVC.DTOs.ProjectTaskDto
@{
    ViewData["Title"] = "Create Task";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="glass-form-container theme-tasks">
                <h3 class="mb-4 border-bottom pb-2 border-light border-opacity-25">Add New Task</h3>

                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-bold"></label>
                        <input asp-for="Title" class="form-control glass-input" />
                        <span asp-validation-for="Title" class="text-warning fw-bold"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold"></label>
                        <textarea asp-for="Description" class="form-control glass-input" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-warning fw-bold"></span>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-4">
                            <label asp-for="ProjectId" class="form-label fw-bold">Project</label>
                            <select asp-for="ProjectId" class="form-select glass-input" asp-items="ViewBag.Projects">
                                <option value="">-- Select Project --</option>
                            </select>
                            <span asp-validation-for="ProjectId" class="text-warning fw-bold"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DeveloperId" class="form-label fw-bold">Assignee</label>
                            <select asp-for="DeveloperId" class="form-select glass-input" asp-items="ViewBag.Developers">
                                <option value="">-- Unassigned --</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label fw-bold">Status</label>
                            <select asp-for="Status" class="form-select glass-input">
                                <option value="To Do">To Do</option>
                                <option value="In Progress">In Progress</option>
                                <option value="Done">Done</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-glass">Back to List</a>
                        <button type="submit" class="btn btn-glass fw-bold">Save Task</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}