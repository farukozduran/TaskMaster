@model IEnumerable<TaskMaster.MVC.DTOs.ProjectTaskDto>
@{
    ViewData["Title"] = "Project Tasks";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Tasks Management</h2>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-dark"><i class="bi bi-plus-lg"></i> Add New Task</a>
        }
    </div>

    <div class="glass-table-container theme-tasks">
        <table class="glass-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Project</th>
                    <th>Assignee</th>
                    <th>Status</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th class="text-end">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.Title</td>
                            <td>@item.ProjectName</td>
                            <td>@(string.IsNullOrEmpty(item.DeveloperFullName) ? "Unassigned" : item.DeveloperFullName)</td>
                            <td>
                                @if (item.Status == "Done")
                                {
                                    <span class="badge bg-success opacity-75">@item.Status</span>
                                }
                                else if (item.Status == "In Progress")
                                {

                                    <span class="badge bg-warning text-dark opacity-75">@item.Status</span>
                                }
                                else
                                {

                                    <span class="badge bg-light text-dark opacity-75">@item.Status</span>
                                }
                            </td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.ProjectTaskId" class="btn btn-sm btn-glass me-2">Edit</a>
                                    <form asp-action="Delete" asp-route-id="@item.ProjectTaskId" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this task?');">Delete</button>
                                    </form>
                                </td>
                            }
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center py-4">No tasks found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>