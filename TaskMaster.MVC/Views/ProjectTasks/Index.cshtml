@model IEnumerable<TaskMaster.MVC.DTOs.ProjectTaskDto>
@{
    ViewData["Title"] = "Project Tasks";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Tasks Management</h2>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Add New Task
            </a>
        }
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Project</th>
                        <th>Assignee</th>
                        <th>Status</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th class="text-end pe-4">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle fw-bold">@item.Title</td>
                                <td class="align-middle"><span class="badge bg-secondary">@item.ProjectName</span></td>
                                <td class="align-middle">
                                    @if (string.IsNullOrEmpty(item.DeveloperFullName))
                                    {
                                        <span class="text-muted fst-italic">Unassigned</span>
                                    }
                                    else
                                    {
                                        <span class="text-primary fw-semibold">@item.DeveloperFullName</span>
                                    }
                                </td>
                                <td class="align-middle">
                                    @if (item.Status == "Done")
                                    {
                                        <span class="badge bg-success">@item.Status</span>
                                    }
                                    else if (item.Status == "In Progress")
                                    {

                                        <span class="badge bg-warning text-dark">@item.Status</span>
                                    }
                                    else
                                    {

                                        <span class="badge bg-light text-dark border">@item.Status</span>
                                    }
                                </td>

                                @if (User.IsInRole("Admin"))
                                {
                                    <td class="text-end pe-3">
                                        <a asp-action="Edit" asp-route-id="@item.ProjectTaskId" class="btn btn-sm btn-outline-primary me-2">Edit</a>
                                        <form asp-action="Delete" asp-route-id="@item.ProjectTaskId" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this task?');">Delete</button>
                                        </form>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">No tasks found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>