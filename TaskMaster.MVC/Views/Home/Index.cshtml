@model IEnumerable<TaskMaster.MVC.DTOs.ProjectDto>
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <div class="glass-form-container theme-dashboard mb-4 p-4">
        <h2 class="text-white">Welcome back, @User.Identity.Name!</h2>
        <p class="text-white opacity-75">
            This is your centralized project management hub. Below you can find an overview of your ongoing projects and their status.
            Use the navigation menu above to manage departments, developers, and tasks.
        </p>
    </div>

    <div class="glass-table-container theme-dashboard">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="text-white"><i class="bi bi-graph-up"></i> Recent Project Status</h4>
        </div>

        <table class="glass-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Project Name</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.ProjectId</td>
                            <td>@item.Name</td>
                            <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                            <td>@(item.EndDate.HasValue ? item.EndDate.Value.ToString("yyyy-MM-dd") : "-")</td>
                            <td>
                                @if (item.EndDate.HasValue && item.EndDate.Value < DateTime.Now)
                                {
                                    <span class="badge bg-success opacity-75">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark opacity-75">Ongoing</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 opacity-75">No projects found in the system.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>