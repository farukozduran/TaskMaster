@model IEnumerable<TaskMaster.MVC.DTOs.ProjectDto>
@{
    ViewData["Title"] = "Projects";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Projects Management</h2>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Add New Project
            </a>
        }
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Project Name</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th class="text-end pe-4">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle">@item.ProjectId</td>
                                <td class="align-middle fw-bold">@item.Name</td>
                                <td class="align-middle">@item.StartDate.ToString("yyyy-MM-dd")</td>
                                <td class="align-middle">@(item.EndDate.HasValue ? item.EndDate.Value.ToString("yyyy-MM-dd") : "-")</td>

                                @if (User.IsInRole("Admin"))
                                {
                                    <td class="text-end pe-3">
                                        <a asp-action="Edit" asp-route-id="@item.ProjectId" class="btn btn-sm btn-outline-primary me-2">
                                            Edit
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.ProjectId" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this project?');">
                                                Delete
                                            </button>
                                        </form>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">No projects found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>