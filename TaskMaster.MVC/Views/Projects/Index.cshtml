@model IEnumerable<TaskMaster.MVC.DTOs.ProjectDto>
@{
    ViewData["Title"] = "Projects";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Projects Management</h2>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-dark"><i class="bi bi-plus-lg"></i> Add New Project</a>
        }
    </div>

    <div class="glass-table-container theme-projects">
        <table class="glass-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Project Name</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th class="text-end">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ProjectId</td>
                            <td class="fw-bold">@item.Name</td>
                            <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                            <td>@(item.EndDate.HasValue ? item.EndDate.Value.ToString("yyyy-MM-dd") : "--")</td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.ProjectId" class="btn btn-sm btn-glass me-2">Edit</a>
                                    <form asp-action="Delete" asp-route-id="@item.ProjectId" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?');">Delete</button>
                                    </form>
                                </td>
                            }
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center py-4">No projects found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>