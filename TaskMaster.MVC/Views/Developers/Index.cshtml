@model IEnumerable<TaskMaster.MVC.DTOs.DeveloperDto>
@{
    ViewData["Title"] = "Developers";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Developers Management</h2>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-dark"><i class="bi bi-plus-lg"></i> Add New Developer</a>
        }
    </div>

    <div class="glass-table-container theme-developers">
        <table class="glass-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Full Name</th>
                    <th>Title</th>
                    <th>Department</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th class="text-end">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.DeveloperId</td>
                            <td class="fw-bold">@item.FirstName @item.LastName</td>
                            <td>@item.Title</td>
                            <td><span class="badge bg-light text-dark opacity-75">@item.DepartmentName</span></td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.DeveloperId" class="btn btn-sm btn-glass me-2">Edit</a>
                                    <form asp-action="Delete" asp-route-id="@item.DeveloperId" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?');">Delete</button>
                                    </form>
                                </td>
                            }
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center py-4">No developers found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>