@model TaskMaster.MVC.DTOs.DeveloperDto
@{
    ViewData["Title"] = "Edit Developer";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="glass-form-container theme-developers">
                <h3 class="mb-4 border-bottom pb-2 border-light border-opacity-25">Edit Developer</h3>

                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="DeveloperId" />

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label fw-bold">First Name</label>
                            <input asp-for="FirstName" class="form-control glass-input" />
                            <span asp-validation-for="FirstName" class="text-warning fw-bold"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label fw-bold">Last Name</label>
                            <input asp-for="LastName" class="form-control glass-input" />
                            <span asp-validation-for="LastName" class="text-warning fw-bold"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-bold">Title / Position</label>
                        <input asp-for="Title" class="form-control glass-input" />
                        <span asp-validation-for="Title" class="text-warning fw-bold"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="DepartmentId" class="form-label fw-bold">Department</label>
                        <select asp-for="DepartmentId" class="form-select glass-input" asp-items="ViewBag.Departments">
                            <option value="">-- Select a Department --</option>
                        </select>
                        <span asp-validation-for="DepartmentId" class="text-warning fw-bold"></span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-glass">Back to List</a>
                        <button type="submit" class="btn btn-glass fw-bold">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}